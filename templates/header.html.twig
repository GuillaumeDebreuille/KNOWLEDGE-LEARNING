<head>
    <meta charset="UTF-8">
    <title>Mon site Symfony</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</head>


<div class="header_all">
    {% if app.user %}
    {# if user is logged in #}

        {% if 'ROLE_ADMIN' in app.user.roles %}
        {# if user is logged in and role = ROLE_ADMIN #}

        <p class="header_title">Admin Mode</p>

        <div class="header_link_box">
            <a class="header_link" href="{{ path('app_home') }}">Accueil</a>
            <a class="header_link" href="{{ path('app_shop') }}">Shop</a>
            <a class="header_link" href="{{ path('app_cart') }}">Mon Panier</a>
            <a class="header_link" href="{{ path('app_account') }}">Mes cours</a>
            <a class="header_link" href="{{ path('app_certification_list') }}">Mes certifications</a>
            <a class="header_link" href="{{ path('app_admin') }}">Admin</a>
            <a class="header_link" href="{{ path('app_logout') }}">Déconnexion</a>
        </div>

        {% elseif 'ROLE_USER' in app.user.roles %}
        {# if user is logged in and role = ROLE_USER #}

            {% if app.user.isVerified %}
            {# if user is logged in and role = ROLE_USER and email isVerified = 1 #}

            <p>User Mode / Mail Verified</p>

            <div class="header_link_box">
                <a class="header_link" href="{{ path('app_home') }}">Accueil</a>
                <a class="header_link" href="{{ path('app_shop') }}">Shop</a>
                <a class="header_link" href="{{ path('app_cart') }}">Mon Panier</a>
                <a class="header_link" href="{{ path('app_certification_list') }}">Mes certifications</a>
                <a class="header_link" href="{{ path('app_account') }}">Mes cours</a>
                <a class="header_link" href="{{ path('app_logout') }}">Déconnexion</a>
            </div>

            {% else %}
            {# if user is logged in and role = ROLE_USER and email isVerified = 0 #}

            <p>User Mode / Mail not Verified</p>

            <div class="header_link_box">
                <a class="header_link" href="{{ path('app_home') }}">Accueil</a>
                <a class="header_link" href="{{ path('app_shop') }}">Shop</a>
                <a class="header_link" href="{{ path('app_logout') }}">Déconnexion</a>
            </div>

            {% endif %}

        {% endif %}

    {% else %}

    <p>No connected Mode</p>

    <div class="header_link_box">
        <a class="header_link" href="{{ path('app_home') }}">Accueil</a>
        <a class="header_link" href="{{ path('app_shop') }}">Shop</a>
        <a class="header_link" href="{{ path('app_login') }}">Connexion</a>
        <a class="header_link" href="{{ path('app_register') }}">Inscription</a>
    </div>

    {% endif %}

</div>
<br>


<style>
    .header_all {
        background-color: #0074c7 
;
    }
    .header_title {
    }

    .header_link_box {
        display: flex;
        padding-bottom: 35px;
    }
    .header_link {
        margin: auto;
        text-decoration: none;
        color: #82b864;
        font-size: 20px;
        font-weight: 900;
    }
    .header_link:hover {
        color: #cd2c2e ;
    }
    .header_link:active {
        color: #4d1919 ;
    }

</style>
